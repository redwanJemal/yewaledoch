# App
APP_NAME=YeWaledoch
APP_URL=https://your-domain.com
APP_ENV=development
DEBUG=false

# Telegram Bot
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=YeWaledochBot
BOT_NAME=YeWaledoch
BOT_DESCRIPTION=የኢትዮጵያ ወላጆች ማህበረሰብ — ልምድ ይጋሩ፣ ምክር ያግኙ
BOT_SHORT_DESCRIPTION=Ethiopian Parenting Community
MINI_APP_URL=https://your-miniapp-domain.com

# Admin (comma-separated Telegram user IDs)
ADMIN_TELEGRAM_IDS=123456789

# Database
DATABASE_URL=postgresql+asyncpg://yewaledoch:secret@db:5432/yewaledoch
POSTGRES_USER=yewaledoch
POSTGRES_PASSWORD=secret
POSTGRES_DB=yewaledoch

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=change-me-in-production-use-long-random-string
JWT_SECRET=change-me-in-production-use-long-random-string

# CORS
CORS_ORIGINS=https://your-domain.com

# MinIO / S3 Storage
MINIO_ENDPOINT=https://storage.endlessmaker.com
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET=yewaledoch

# AI Translation
ANTHROPIC_API_KEY=your_anthropic_api_key

# Frontend
VITE_API_URL=https://your-api-domain.com
VITE_BOT_USERNAME=YeWaledochBot
