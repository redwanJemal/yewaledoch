# =============================================================================
# YeWaledoch Production Environment Variables
# Copy to .env and fill in real values before deploying
# =============================================================================

# --- App ---
APP_NAME=YeWaledoch
APP_ENV=production
APP_URL=https://yewaledoch.endlessmaker.com
DEBUG=false

# --- Database ---
POSTGRES_USER=yewaledoch
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=yewaledoch

# --- Security ---
SECRET_KEY=CHANGE_ME_RANDOM_64_CHAR_STRING
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=https://yewaledoch.endlessmaker.com

# --- Telegram Bot ---
# Get from @BotFather
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
BOT_USERNAME=YeWaledochBot
# These are set automatically on each startup via the Telegram Bot API
BOT_NAME=YeWaledoch
BOT_DESCRIPTION=የኢትዮጵያ ወላጆች ማህበረሰብ — ልምድ ይጋሩ፣ ምክር ያግኙ
BOT_SHORT_DESCRIPTION=Ethiopian Parenting Community
MINI_APP_URL=https://yewaledoch.endlessmaker.com
# Comma-separated Telegram user IDs of admins
ADMIN_TELEGRAM_IDS=123456789

# --- MinIO / S3 Storage ---
MINIO_ENDPOINT=https://storage.endlessmaker.com
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET=yewaledoch

# --- AI Translation (Claude API) ---
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxx

# --- Frontend Build Args ---
VITE_API_URL=https://yewaledoch.endlessmaker.com/api/v1
VITE_BOT_USERNAME=YeWaledochBot

# --- Docker Registry (set in GitLab CI/CD variables) ---
CI_REGISTRY_IMAGE=registry.gitlab.com/your-group/yewaledoch
IMAGE_TAG=latest
